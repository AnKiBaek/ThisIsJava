package practice5_1.sec07;

public class StakMethodExample {
	
	int foo(int b) {
		
		int a = 6;
		
		return a*b + 10;
		
	}
	int var(int x) {
		int y =3;
		return foo(x*y);
	}

	public static void main(String[] args) {
		
		
		StakMethodExample sme = new StakMethodExample();
	
		System.out.println(sme.var(10));

	}

}
