package practice5_10.sec06;

public class ArrayCreateByExample {

	public static void main(String[] args) {
		// int 배열
		int[] arr1 = new int[3];
		
		//초기값 출력
		for(int i = 0;i<arr1.length;i++) {
			System.out.println(arr1[i]);
		}
		System.out.println();
		
		for(int i = 0;i<arr1.length;i++) {
			arr1[i] = i;
			System.out.println(arr1[i]);
		}
		
		System.out.println();
		
		// double 배열
		double[] arr2 = new double[3];
		
		//초기값 출력
		for(int i=0 ; i<arr2.length; i++) {
			System.out.println(arr2[i]);
		}
		
		System.out.println();
		
	
		for(int i = 0;i<arr2.length;i++) {
			arr2[i] = i +123;
			System.out.println(arr2[i]);
		}
		
		
		System.out.println();
		
		// String 배열
		String[] strArr = new String[3];
		
		for(String a : strArr) {
			System.out.println(a);
		}
		
		strArr[0] = "우";
		strArr[1] = "테코 갈수있다";
		strArr[2] = "화이팅";
		
		for(String a : strArr) {
			System.out.printf(a);
		}
		

	}

}
