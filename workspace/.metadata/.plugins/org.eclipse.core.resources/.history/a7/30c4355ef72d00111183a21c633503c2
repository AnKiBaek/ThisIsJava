package practice6_05.sec14;

public class Car {
	int speed;
	boolean stop;
	
	public int getSpeed() {
		return speed;
	}
	public void setSpeed(int speed) {
		if(0>speed) {
			speed = 0;
		}
		this.speed = speed;
	}
	public boolean isStop() {
		if(stop == true) {
			speed = 0;
		}
		return stop;
	}
	public void setStop(boolean stop) {
		if(stop == true) {
			speed = 0;
		}
		this.stop = stop;
	}
	
	

}
