package practice5_1.sec06;

public class ArrayCreateByNewExample {

	public static void main(String[] args) {
		//배열변수 선언과 배열 생성
		int[] arr1 = new int[3];
		//배열항목의 초기값 출력
		for(int i = 0; i < arr1.length ; i++) {
			System.out.println(arr1[i]);
		}
		
		System.out.println();
		
		//인덱스 순서별로값 변경
		arr1[0] = 1;
		arr1[1] = 2;
		arr1[2] = 3;
		
		for(int i = 0; i < arr1.length ; i++) {
			System.out.println(arr1[i]);
		}
		

	}

}
