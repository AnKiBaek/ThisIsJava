package practice8_06.sec06;

public class Audio implements RemoteControl{

	private int vol;
	private int memoryVol;
	@Override
	public void setVol(int vol) {
		if(vol > MAX_VOLUME) {
			this.vol = MAX_VOLUME;
		} else if (vol < MIN_VOLUME) {
			this.vol = MIN_VOLUME;
		}
		System.out.println("Audio볼륨: "+ this.vol);
		
	}@Override
	public void setMute(boolean mute) {
		if(mute) {
			this.memoryVol = this.vol;
			this.vol = MIN_VOLUME;
			System.out.println("Audio 음소거");
		} else {
			this.vol = this.memoryVol;
			System.out.println("Audio 음소거 해제");
		}	
	}@Override
	public void turnOff() {
		System.out.println("Audio 전원끔");
	}@Override
	public void turnOn() {
		System.out.println("Audio 전원켬");	
	}
}
