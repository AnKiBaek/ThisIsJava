package practice5_7.sec10;


public class Ex {
	int sum;
	private int arrValsum(int[]arr) {
		
		for(int i : arr) {
			sum += i;
		}
		
		return sum;
	}

	public static void main(String[] args) {
		
		Ex ex = new Ex();
		

		int[] arr= {100,20,30};
		int sum = ex.arrValsum(arr);
		
		System.out.println(sum);
		
		
	}
}
