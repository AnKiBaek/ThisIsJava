package practice5_4.sec06;

public class ArraysCreateByExample {

	public static void main(String[] args) {
		int[] arr1 = new int[3];
		
		for(int i : arr1) {
			System.out.println(i);
		}
		
		System.out.println();
		for(int i = 0; i< arr1.length ;i++) {
			arr1[i] = i+1;
			System.out.println(arr1[i]);
		}
		
		double[] arr2 = new double[3];
		
		System.out.println();
		for(double d: arr2) {
			System.out.println(d);
		}
		
		System.out.println();
		for(int i = 0; i< arr2.length ;i++) {
			arr2[i] = i+1;
			System.out.println(arr2[i]);
		}
		

		System.out.println();
		String[] arr3 = new String[3];
		
		for(String s : arr3) {
			System.out.println(s);
		}
		
		arr3[0] = "우";
		arr3[1] = "우";
		arr3[2] = "우";
		
		Sysout
		
		for(String s: arr3) {
			System.out.printf(s);
		}
	}

}
