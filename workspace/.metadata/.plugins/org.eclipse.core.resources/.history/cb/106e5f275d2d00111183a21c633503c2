package practice6_04.sec08.exam03;

public class Cellphone {
	
	int battery;
	String choice;
	
	void setBattery(int battery) {
		this.battery = battery;
	}
	
	boolean isLeftBattery() {
		if(battery == 0) {
			System.out.println("배터리가없습니다");
			return false;
		}	
		System.out.println("배터리가있습니다.");
		return true;
	}
	
	void batteryLow() {
		if(0<battery) {
			System.out.println("실행중.... 배터리 잔량 : " + battery);
			battery --;
			if(10 == battery) {
				System.out.println("배터리가 10% 남았음");
				System.out.println("충전? y / n");
			}
		} 
		
	}
	
	

}
