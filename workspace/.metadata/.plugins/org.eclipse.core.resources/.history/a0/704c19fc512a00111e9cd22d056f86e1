public class AdvancedForExample {
	
	
	public static int sumScores(int[]arr) {
		
		int sum  = 0;
		for(int i : arr) {	
			sum+= i;
		}
		return sum;
	}
	
	public static void avgScores(int[] arr, int sumVal) {
		double avg = 0;
		avg = (double)sumVal / arr.length;
		System.out.println("평균: " + avg);
	}
	

