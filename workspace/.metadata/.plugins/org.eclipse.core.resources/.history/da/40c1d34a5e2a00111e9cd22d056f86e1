package practice5_8;

public class AdvancedForExample {

	public static void main(String[] args) {
		
		int[] arr = {10,20,30,40};
		int sum = 0;
		int idex = 0;
		for(int a : arr) {
			System.out.println(idex + ": "+a);
			idex++;
			sum += a;
		}
		System.out.println("합계: "+sum);
		
		String[] strArr = {"10","20","30","40"};
		String str = "";
		int idex2 = 0;
		for(String s: strArr) {
			System.out.println(idex2+": "+s);
			idex2++;
			str += Integer.parseInt(str);
		}
		
		System.out.println(str);

	}

}
