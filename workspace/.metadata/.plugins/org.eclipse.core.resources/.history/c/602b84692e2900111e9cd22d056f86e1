package practice5_8.sec06;

public class MultidimensionalArrayByValueListExample {

	public static void main(String[] args) {
		int[][] arr = {{1,23,23,23,23},{1232132132,23213}};

		int maxVal = 0;
		int minVal = 0;
		
		int totalCount = 0;
		
		for(int i =0; i<arr.length;i++) {
			totalCount += arr[i].length;
			for(int k = 0; k < totalCount-1; k++) {
				if(arr[i][k] < arr[i][k+1]) {
					arr[i][k+1] =arr[i][k];
					System.out.println(arr[i][k+1]);
				}
				
			}
		}
		
	}
	
	

}
