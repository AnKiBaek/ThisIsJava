package practice8_01.sec06;

public class RemoteControlExample {
	public static void main(String[] args) {
		RemoteControl tv = new Television();
		tv.turnOn();
		tv.setVolume(100);
		tv.setVolume(9);
		
		
		if(tv instanceof Television tv2) {
			tv.setVolume(10);
			tv2.setMute(true);
			System.out.println(tv2.getVolume());
			
		
		}
		
		
		
		
		tv.turnOff();
	}

}
