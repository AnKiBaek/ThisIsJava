package practice5_2.sec06;

public class ArrayCreateByExample {

	public static void main(String[] args) {
		
		int[] arr1 = new int[3];
		
		for(int a : arr1) {
			System.out.println(a);
		}
		
		System.out.println();
		
		for(int i = 0 ; i< arr1.length; i++) {
			arr1[i] = i;
			System.out.println(arr1[i]);
		}
		
		double[] arr2 = new double[3];
		
		for(double a : arr2) {
			System.out.println(a);
		}
		
	}

}
