package practice6_03.sec08.exam03;

import java.util.Scanner;

public class Cellphone {
	
	int battery;
	String choice;
	
	Scanner sc = new Scanner(System.in);
	
	void setBattery(int battery) {
		this.battery = battery;
	}
	
	boolean powerOn() {
		
		if(battery == 0) {
			System.out.println("배터리가 없습니다.");
			return false;
		}
		
		System.out.println("배터리가 있습니다.");
		System.out.println("전원을 켭니까? y / n");
		
		sc.hasNextLine();
		switch(choice) {
		case "y" : System.out.println("전원 킴"); return true;
		case "n" : System.out.println("전원 안킴"); return false;
		default  : return false;
		}
	
		
	}
	
	void batteryLow() {
		while(true) {
			if(battery>0) {
				System.out.println("실행중.... 배터리 잔량: " + battery);
				battery --;
				if(battery == 10) {
					System.out.println("배터리가"+ battery +"% 남았습니다.");
					System.out.println("충전 하시겠습니까? y / n");
					sc.hasNextLine();
					switch(choice) {
					case "y" : System.out.println("10% 충전함"); battery +=10;
					case "n" : System.out.println("충전안함"); 
					}
				}
			} else {
				System.out.println("배터리가 없습니다. 배터리 잔량: " + battery);
				return;
			}
		}
		
	}

}
