package practice6_09;

public class Car {
	
	int gas;
	
	void setGas(int gas) {
		this.gas = gas;
	}
	
	//결론적으로 참 거짓을 리턴한다.
	boolean isLeftGas() {
		if(gas==0) {
			System.out.println("가스가 없다.");
			return false;
		}
		System.out.println("가스가 있다.");
		return true;
	}
	
	void run() {
		while(true) {
			if(gas > 0) {
				System.out.println("달립니다. 남은 가스: " + gas);
				gas--;
			} else {
				System.out.println("멈춤니다. 남은 가스: " + gas);
				return;
			}
		}
	}

}
