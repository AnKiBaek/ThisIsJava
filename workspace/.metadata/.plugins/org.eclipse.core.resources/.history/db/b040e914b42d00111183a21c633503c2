package practice6_01.sec14;

public class Car {
	private int speed;
	private boolean stop;
	
	
	public int getSpeed() {
		return speed;
	}
	
	
	public void setSpeed(int speed) {
		// 스피드가 0 보다작으면  0 으로 고정
		if(speed<0) {
			speed = 0;
		} else {
		this.speed = speed;
		}
	}
	public boolean isStop() {
		return stop;
	}
	public void setStop(boolean stop) {
		this.stop = stop;
		// stop 이 트루면 스피드 0으로 변경 
		if(stop ==true) {
			this.speed =0;
		}
	}
	
	

}
