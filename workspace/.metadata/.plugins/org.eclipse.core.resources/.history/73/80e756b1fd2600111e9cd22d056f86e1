package ch17.sec08;

import java.util.Arrays;

public class LoopingExample {

	public static void main(String[] args) {
		
		int[] intArr = {1,2,3,4,5};
		
		//잘못작성한 경우
		Arrays.stream(intArr)
		.filter(a -> a%2 ==0)
		.peek(n -> System.out.println(n)); // 최종처리가 아니여서 출력안됨
		
		//중간처리 메서드 peek()을 이용해서 반복 처리
		int total = Arrays.stream(intArr)
				.filter(a -> a%2 == 0)
				.peek(n -> System.out.println(n)) // 동작함
				.sum(); // 최종처리
		
		System.out.println("총합 : "+ total);
		
		//최종 처리 메서드 forEach() 를 이용해서 반복처리
		Arrays.stream(intArr)
		.filter(a -> a%2==0)
		.forEach(a -> System.out.println(a)); // 최종 처리이므로 출력

	}

}
