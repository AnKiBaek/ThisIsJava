package practice5_3.sec06;

import java.util.Iterator;

public class ArrayCreateByExample {

	public static void main(String[] args) {
		int[] arr1 = new int[3];
		
		for(int a : arr1) {
			System.out.println(a);
		}
		
		System.out.println();
		
		for(int i  = 0 ; i < arr1.length ; i++) {
			arr1[i] = i ;
			
			System.out.println(arr1[i]);
		}
		
		System.out.println();
		
		double[] arr2 = new double[3];
		
		for(double d:arr2) {
			System.out.println(d);
		}
		
		arr2[0] = 1.1;
		arr2[1] = 1.2;
		arr2[2] = 1.3;
		
		System.out.println();
		
		double result = arr2[0] + arr2[1];
		
		for(double d : arr2) {
			System.out.println(d);
		}
		
		System.out.println();
		System.out.println(result);
		
		
		System.out.println();
		
		String[] arr3 = new String[3];
		
		for(String s : arr3) {
			System.out.println(s);
		}
		
		
		arr3[0] = "우";
		arr3[1] = "테";
		arr3[2] = "코";
		
		for(String s : arr3) {
			System.out.println(s);
		}
		
		
		
		
		

	}

}
