package ch02_6.sec07;

public class PromotionExample {

	public static void main(String[] args) {
		
		int a = 100;
		int vx = 2;
		
		int result = a * 100 + vx ;
		
		System.out.println(result);
		
		//byte -> short
		
		byte bVal = 127;
		short sVal = bVal;
		
		System.out.println(sVal);
		
		//char -> int
		
		char cVal = '아';
		
		int iVal = cVal;
		
		System.out.println(iVal);
		
		String str1 = new String("문자열");
		String str2 = new String("문자열");
		String str12 ="문자열";
		String str13 ="문자열";
		
		
		System.out.println(str1 == str2);
		System.out.println("리터럴방식 : "+(str12 == str13));
		System.out.println();
		
		System.out.println(str12.equals(str13));
		System.out.println(str1.equals(str2));
		
		System.out.println(System.identityHashCode(str2));
		System.out.println(System.identityHashCode(str1));
		System.out.println(System.identityHashCode(str12));
		System.out.println(System.identityHashCode(str13));
				

	}

}
